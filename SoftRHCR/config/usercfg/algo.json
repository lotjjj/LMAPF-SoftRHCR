{
  "seed": 42,
  "device": "cuda",
  "norm_type": "bn",
  "extractor_backbone": "default",
  "norm_after_concat": "ln",
  "profile": false,
  "profile_interval_s": 5.0,
  "horizon_len": 400,
  "max_train_steps": 1000000,
  "gamma": 0.99,
  "lr": 3e-4,
  "lr_schedule": "linear",
  "min_lr": 2e-5,
  "buffer_size": 20000,
  "batch_size": 256,
  "target_update_interval": 100,
  "save_interval_steps": 100000,
  "optimizer": "Adam",
  "weight_decay": 1e-4,
  "ppo_epoch": 4,
  "clip_param": 0.2,
  "entropy_coef": 0.01,
  "value_loss_coef": 0.5,
  "use_gae": true,
  "gae_lambda": 0.95
}
